CREATE TABLE profils (
    id               UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    utilisateur_id   UUID NOT NULL REFERENCES utilisateurs(id) ON DELETE CASCADE,
    filiere_id       INTEGER REFERENCES filieres(id),
    bio              TEXT,
    annee_etude      VARCHAR(10),
    disponibilites   TEXT,
    objectifs        TEXT,
    experience_pro   TEXT,
    linkedin_url     VARCHAR(500),
    github_url       VARCHAR(500),
    note_moyenne     NUMERIC(3,2) DEFAULT 0,
    nb_sessions      INTEGER DEFAULT 0,
    profil_complete  SMALLINT DEFAULT 0,
    cree_le          TIMESTAMP DEFAULT NOW(),
    mis_a_jour_le    TIMESTAMP DEFAULT NOW()
);

CREATE TABLE competences (
    id        SERIAL PRIMARY KEY,
    nom       VARCHAR(100) NOT NULL UNIQUE,
    categorie VARCHAR(50)
);

CREATE TABLE profil_competences (
    profil_id     UUID REFERENCES profils(id) ON DELETE CASCADE,
    competence_id INTEGER REFERENCES competences(id) ON DELETE CASCADE,
    niveau        VARCHAR(20) CHECK (niveau IN ('debutant','intermediaire','avance','expert')),
    en_tant_que   VARCHAR(10) CHECK (en_tant_que IN ('offre','recherche')),
    PRIMARY KEY (profil_id, competence_id, en_tant_que)
);

CREATE TABLE offres_mentorat (
    id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    auteur_id   UUID NOT NULL REFERENCES utilisateurs(id) ON DELETE CASCADE,
    type        VARCHAR(10) NOT NULL CHECK (type IN ('offre','demande')),
    titre       VARCHAR(200) NOT NULL,
    description TEXT,
    statut      VARCHAR(20) DEFAULT 'active' CHECK (statut IN ('active','archivee','pourvue')),
    cree_le     TIMESTAMP DEFAULT NOW(),
    expire_le   DATE
);

CREATE TABLE matchings (
    id                UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    mentor_id         UUID NOT NULL REFERENCES utilisateurs(id),
    mentore_id        UUID NOT NULL REFERENCES utilisateurs(id),
    score_global      NUMERIC(5,2) NOT NULL,
    score_competences NUMERIC(5,2),
    score_filieres    NUMERIC(5,2),
    score_horaires    NUMERIC(5,2),
    statut            VARCHAR(20) DEFAULT 'suggere' CHECK (statut IN ('suggere','accepte','refuse','en_cours','termine')),
    initie_par        VARCHAR(10) CHECK (initie_par IN ('mentor','mentore','systeme')),
    cree_le           TIMESTAMP DEFAULT NOW(),
    mis_a_jour_le     TIMESTAMP DEFAULT NOW(),
    UNIQUE (mentor_id, mentore_id)
);

CREATE TABLE sessions (
    id            UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    matching_id   UUID NOT NULL REFERENCES matchings(id) ON DELETE CASCADE,
    titre         VARCHAR(200),
    date_debut    TIMESTAMP NOT NULL,
    date_fin      TIMESTAMP NOT NULL,
    lien_reunion  VARCHAR(500),
    lieu          VARCHAR(200),
    modalite      VARCHAR(15) DEFAULT 'distanciel' CHECK (modalite IN ('distanciel','presentiel','hybride')),
    statut        VARCHAR(20) DEFAULT 'planifiee' CHECK (statut IN ('planifiee','confirmee','en_cours','terminee','annulee')),
    notes_mentor  TEXT,
    notes_mentore TEXT,
    cree_le       TIMESTAMP DEFAULT NOW()
);

CREATE TABLE evaluations (
    id             UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    session_id     UUID NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    evaluateur_id  UUID NOT NULL REFERENCES utilisateurs(id),
    evalue_id      UUID NOT NULL REFERENCES utilisateurs(id),
    note           SMALLINT NOT NULL CHECK (note BETWEEN 1 AND 5),
    commentaire    TEXT,
    cree_le        TIMESTAMP DEFAULT NOW(),
    UNIQUE (session_id, evaluateur_id)
);

CREATE TABLE conversations (
    id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    matching_id UUID REFERENCES matchings(id),
    cree_le     TIMESTAMP DEFAULT NOW()
);

CREATE TABLE conversation_participants (
    conversation_id UUID REFERENCES conversations(id) ON DELETE CASCADE,
    utilisateur_id  UUID REFERENCES utilisateurs(id) ON DELETE CASCADE,
    PRIMARY KEY (conversation_id, utilisateur_id)
);

CREATE TABLE messages (
    id              UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    conversation_id UUID NOT NULL REFERENCES conversations(id) ON DELETE CASCADE,
    expediteur_id   UUID NOT NULL REFERENCES utilisateurs(id),
    contenu         TEXT NOT NULL,
    lu              BOOLEAN DEFAULT FALSE,
    envoye_le       TIMESTAMP DEFAULT NOW()
);

CREATE TABLE notifications (
    id              UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    destinataire_id UUID NOT NULL REFERENCES utilisateurs(id) ON DELETE CASCADE,
    type            VARCHAR(50) NOT NULL,
    titre           VARCHAR(200),
    contenu         TEXT,
    lien            VARCHAR(500),
    lu              BOOLEAN DEFAULT FALSE,
    cree_le         TIMESTAMP DEFAULT NOW()
);
